<?xml version="1.0"?>
<Container version="2">
  <Name>CargoPilot</Name>
  <Repository>jeffersonmouze/cargopilot:latest</Repository>
  <Registry>https://hub.docker.com/</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>bash</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/jeffreymooiweer/CargoPilot</Support>
  <Project>https://github.com/jeffreymooiweer/CargoPilot</Project>
  <Overview>Webapp voor het berekenen van gewicht en volume van bouwmaterialen en het genereren van appendices.</Overview>
  <Category>Productivity: Tools</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/jeffreymooiweer/CargoPilot/main/unraid/CargoPilot.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/jeffreymooiweer/CargoPilot/main/assets/images/shipping.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="Web Port" Target="8080" Default="8080" Mode="tcp" Description="Web UI port" Type="Port" Display="always" Required="true" Mask="false">8080</Config>
  <Config Name="Data" Target="/data" Default="/mnt/user/appdata/cargopilot" Mode="rw" Description="Persistent data" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/cargopilot</Config>
  <Config Name="TZ" Target="TZ" Default="Europe/Amsterdam" Mode="" Description="Timezone" Type="Variable" Display="always" Required="false" Mask="false">Europe/Amsterdam</Config>
  <Config Name="APP_SECRET_KEY" Target="APP_SECRET_KEY" Default="" Mode="" Description="Secret key for sessions" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="ADMIN_USERNAME" Target="ADMIN_USERNAME" Default="admin" Mode="" Description="Bootstrap admin username" Type="Variable" Display="always" Required="false" Mask="false">admin</Config>
  <Config Name="ADMIN_EMAIL" Target="ADMIN_EMAIL" Default="admin@example.local" Mode="" Description="Bootstrap admin email" Type="Variable" Display="always" Required="false" Mask="false">admin@example.local</Config>
  <Config Name="ADMIN_PASSWORD" Target="ADMIN_PASSWORD" Default="" Mode="" Description="Bootstrap admin password" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="PUID" Target="PUID" Default="1000" Mode="" Description="User ID for /data volume permissions" Type="Variable" Display="advanced" Required="false" Mask="false">1000</Config>
  <Config Name="PGID" Target="PGID" Default="1000" Mode="" Description="Group ID for /data volume permissions" Type="Variable" Display="advanced" Required="false" Mask="false">1000</Config>
</Container>
